<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifikasi Kehadiran"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Card Foto -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFoto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E1E3A"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgFoto"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="#2A2A4A"
                    android:scaleType="centerCrop"
                    android:padding="8dp"/>

                <Button
                    android:id="@+id/btnAmbilFoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷  Ambil Foto Selfie"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#7C3AED"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Input ID -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E1E3A"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardFoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID KARYAWAN"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"/>

                <EditText
                    android:id="@+id/etIdKaryawan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contoh: EMP-1092"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#7C3AED"
                    android:textSize="18sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol Verifikasi -->
        <Button
            android:id="@+id/btnVerifikasi"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="VERIFIKASI DATA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:backgroundTint="#7C3AED"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/cardInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>